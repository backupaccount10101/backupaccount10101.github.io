---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>backupaccount10101</h1>
			<p>
				Vulnerability analysis and defensive engineering notes. Writeups on published CVEs and
				advisories, with enough technical depth on the underlying bug class to be useful on its
				own, not just a summary of the headline.
			</p>
			<p>
				See the <a href="/blog">blog</a> for writeups, or <a href="/about">about</a> for contact
				information.
			</p>
		</main>
		<Footer />
	</body>
</html>
